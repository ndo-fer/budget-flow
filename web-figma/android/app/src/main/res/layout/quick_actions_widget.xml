<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@drawable/quick_actions_widget_background"
    android:padding="16dp"
    android:weightSum="10">

    <!-- Left Section: Information (Weight 4.5) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="4.5"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:paddingEnd="12dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@mipmap/ic_launcher" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Budget Flow"
                android:textColor="#29B9AA"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <!-- Saldo / Dana Bersih -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dana Bersih"
            android:textColor="#7B6E67"
            android:textSize="10sp"
            android:layout_marginTop="8dp" />
            
        <TextView
            android:id="@+id/txt_saldo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rp -"
            android:textColor="#1A2B38"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Limit Harian / Safe-to-Spend -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Batas Harian HARI INI"
            android:textColor="#7B6E67"
            android:textSize="9sp"
            android:layout_marginTop="6dp" />
            
        <TextView
            android:id="@+id/txt_limit_harian"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rp -"
            android:textColor="#FF6B58"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Divider Line -->
    <FrameLayout
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="#1A000000" />

    <!-- Right Section: Quick Actions (Weight 5.5) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="5.5"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="12dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Quick Actions"
            android:textColor="#7B6E67"
            android:textSize="9sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center"
            android:weightSum="3">

            <!-- Button 1: Tambah Expense -->
            <LinearLayout
                android:id="@+id/btn_add_expense"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.2"
                android:background="@drawable/widget_button_accent"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="6dp"
                android:clickable="true"
                android:focusable="true">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold" />
                    
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tambah"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Button 2: Ledger -->
            <LinearLayout
                android:id="@+id/btn_ledger"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.9"
                android:background="@drawable/widget_button_secondary"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="6dp"
                android:clickable="true"
                android:focusable="true">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📅"
                    android:textSize="16sp" />
                    
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ledger"
                    android:textColor="#1A2B38"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Button 3: Wallets -->
            <LinearLayout
                android:id="@+id/btn_wallets"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.9"
                android:background="@drawable/widget_button_secondary"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💳"
                    android:textSize="16sp" />
                    
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Wallets"
                    android:textColor="#1A2B38"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
