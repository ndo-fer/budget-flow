<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@drawable/quick_actions_widget_background"
    android:padding="10dp"
    android:weightSum="10">

    <!-- Left Column: Information Panel (Weight 3.8) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="3.8"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:paddingEnd="2dp">

        <!-- Logo & App Name Header -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">
            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@mipmap/ic_launcher" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Budget Flow"
                android:textColor="#29B9AA"
                android:textSize="9.5sp"
                android:textStyle="bold"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <!-- Saldo / Dana Bersih -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DANA BERSIH"
            android:textColor="#7B6E67"
            android:textSize="8sp"
            android:textStyle="bold"
            android:textAllCaps="true" />
            
        <TextView
            android:id="@+id/txt_saldo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rp -"
            android:textColor="#1A2B38"
            android:textSize="15.5sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <!-- Limit Harian / Safe-to-Spend -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BATAS HARI INI"
            android:textColor="#7B6E67"
            android:textSize="8sp"
            android:textStyle="bold"
            android:textAllCaps="true" />
            
        <TextView
            android:id="@+id/txt_limit_harian"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rp -"
            android:textColor="#FF6B58"
            android:textSize="13.5sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Divider Line -->
    <FrameLayout
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="#1A000000"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="8dp" />

    <!-- Right Column: Calculator Keypad & Display (Weight 6.2) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="6.2"
        android:orientation="vertical">

        <!-- Calculator Display Header Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp"
            android:gravity="center_vertical"
            android:weightSum="4">

            <!-- RESET Button (Rst) -->
            <LinearLayout
                android:id="@+id/btn_reset"
                android:layout_width="0dp"
                android:layout_height="24dp"
                android:layout_weight="0.9"
                android:background="@drawable/widget_button_secondary"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rst"
                    android:textColor="#B84A39"
                    android:textSize="9sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Accumulated Display -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="24dp"
                android:layout_weight="2.2"
                android:background="@drawable/display_bg"
                android:gravity="center"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:paddingHorizontal="2dp">
                <TextView
                    android:id="@+id/txt_accumulated_total"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rp 0"
                    android:textColor="#1A2B38"
                    android:textSize="9.5sp"
                    android:textStyle="bold"
                    android:ellipsize="end"
                    android:maxLines="1" />
            </LinearLayout>

            <!-- OK / SIMPAN Button -->
            <LinearLayout
                android:id="@+id/btn_simpan"
                android:layout_width="0dp"
                android:layout_height="24dp"
                android:layout_weight="0.9"
                android:background="@drawable/widget_button_accent"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OK"
                    android:textColor="#FFFFFF"
                    android:textSize="9.5sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- 3x3 Keypad Layout -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:weightSum="3">

            <!-- Row 1: 1k, 2k, 5k -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp"
                android:weightSum="3">

                <!-- +1k -->
                <LinearLayout
                    android:id="@+id/btn_quick_1k"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/note_1k"
                    android:gravity="center"
                    android:layout_marginEnd="4dp"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+1k"
                        android:textColor="#5A5A5A"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- +2k -->
                <LinearLayout
                    android:id="@+id/btn_quick_2k"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/note_2k"
                    android:gravity="center"
                    android:layout_marginEnd="4dp"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+2k"
                        android:textColor="#4A5A4A"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- +5k -->
                <LinearLayout
                    android:id="@+id/btn_quick_5k"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/note_5k"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+5k"
                        android:textColor="#8C5815"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Row 2: 10k, 20k, 50k -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp"
                android:weightSum="3">

                <!-- +10k -->
                <LinearLayout
                    android:id="@+id/btn_quick_10k"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/note_10k"
                    android:gravity="center"
                    android:layout_marginEnd="4dp"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+10k"
                        android:textColor="#5D3891"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- +20k -->
                <LinearLayout
                    android:id="@+id/btn_quick_20k"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/note_20k"
                    android:gravity="center"
                    android:layout_marginEnd="4dp"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+20k"
                        android:textColor="#137A3F"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- +50k -->
                <LinearLayout
                    android:id="@+id/btn_quick_50k"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/note_50k"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+50k"
                        android:textColor="#1A5B8C"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Row 3: 100k, 200k, Custom -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:weightSum="3">

                <!-- +100k -->
                <LinearLayout
                    android:id="@+id/btn_quick_100k"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/note_100k"
                    android:gravity="center"
                    android:layout_marginEnd="4dp"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+100k"
                        android:textColor="#A82020"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- +200k -->
                <LinearLayout
                    android:id="@+id/btn_quick_200k"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/note_200k"
                    android:gravity="center"
                    android:layout_marginEnd="4dp"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+200k"
                        android:textColor="#6C695D"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- + Custom -->
                <LinearLayout
                    android:id="@+id/btn_add_expense"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/widget_button_accent"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+ Cust"
                        android:textColor="#FFFFFF"
                        android:textSize="9.5sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
